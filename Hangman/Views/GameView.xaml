<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="Hangman.Views.GameView"
             >
    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewGameCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveGameCommand}"/>
        <KeyBinding Key="A" Command="{Binding GuessCommand}" CommandParameter="A"/>
        <KeyBinding Key="B" Command="{Binding GuessCommand}" CommandParameter="B"/>
        <KeyBinding Key="C" Command="{Binding GuessCommand}" CommandParameter="C"/>
        <KeyBinding Key="D" Command="{Binding GuessCommand}" CommandParameter="D"/>
        <KeyBinding Key="E" Command="{Binding GuessCommand}" CommandParameter="E"/>
        <KeyBinding Key="F" Command="{Binding GuessCommand}" CommandParameter="F"/>
        <KeyBinding Key="G" Command="{Binding GuessCommand}" CommandParameter="G"/>
        <KeyBinding Key="H" Command="{Binding GuessCommand}" CommandParameter="H"/>
        <KeyBinding Key="I" Command="{Binding GuessCommand}" CommandParameter="I"/>
        <KeyBinding Key="J" Command="{Binding GuessCommand}" CommandParameter="J"/>
        <KeyBinding Key="K" Command="{Binding GuessCommand}" CommandParameter="K"/>
        <KeyBinding Key="L" Command="{Binding GuessCommand}" CommandParameter="L"/>
        <KeyBinding Key="M" Command="{Binding GuessCommand}" CommandParameter="M"/>
        <KeyBinding Key="N" Command="{Binding GuessCommand}" CommandParameter="N"/>
        <KeyBinding Key="O" Command="{Binding GuessCommand}" CommandParameter="O"/>
        <KeyBinding Key="P" Command="{Binding GuessCommand}" CommandParameter="P"/>
        <KeyBinding Key="Q" Command="{Binding GuessCommand}" CommandParameter="Q"/>
        <KeyBinding Key="R" Command="{Binding GuessCommand}" CommandParameter="R"/>
        <KeyBinding Key="S" Command="{Binding GuessCommand}" CommandParameter="S"/>
        <KeyBinding Key="T" Command="{Binding GuessCommand}" CommandParameter="T"/>
        <KeyBinding Key="U" Command="{Binding GuessCommand}" CommandParameter="U"/>
        <KeyBinding Key="V" Command="{Binding GuessCommand}" CommandParameter="V"/>
        <KeyBinding Key="W" Command="{Binding GuessCommand}" CommandParameter="W"/>
        <KeyBinding Key="X" Command="{Binding GuessCommand}" CommandParameter="X"/>
        <KeyBinding Key="Y" Command="{Binding GuessCommand}" CommandParameter="Y"/>
        <KeyBinding Key="Z" Command="{Binding GuessCommand}" CommandParameter="Z"/>
    </UserControl.InputBindings>

    <DockPanel Background="#FFE8B0">
        <Menu DockPanel.Dock="Top" Background="#FFFFE0" Padding="2">
            <MenuItem Header="_File">
                <MenuItem Header="_New Game" Command="{Binding NewGameCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Save Game" Command="{Binding SaveGameCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="_Statistics" Command="{Binding StatisticsCommand}"/>
                <Separator/>
                <MenuItem Header="_Cancel" Command="{Binding CancelCommand}"/>
            </MenuItem>
            <MenuItem Header="_Categories">
                <MenuItem Header="All categories" Command="{Binding SetCategoryCommand}" CommandParameter="All Categories"/>
                <MenuItem Header="Cars" Command="{Binding SetCategoryCommand}" CommandParameter="Cars"/>
                <MenuItem Header="Movies" Command="{Binding SetCategoryCommand}" CommandParameter="Movies"/>
                <MenuItem Header="States" Command="{Binding SetCategoryCommand}" CommandParameter="States"/>
                <MenuItem Header="Mountains" Command="{Binding SetCategoryCommand}" CommandParameter="Mountains"/>
                <MenuItem Header="Rivers" Command="{Binding SetCategoryCommand}" CommandParameter="Rivers"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Source="{Binding HangmanImagePath}" Margin="20" Stretch="Uniform" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Margin="20" VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                    <Image Source="{Binding CurrentUser.ImagePath}" Width="40" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding CurrentUser.Name}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="{Binding CurrentWordDisplay}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,30" FontFamily="Consolas"/>

                <ItemsControl ItemsSource="{Binding Keyboard}" HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel MaxWidth="450" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Char}" 
                                    Command="{Binding DataContext.GuessCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                                    CommandParameter="{Binding Char}" 
                                    IsEnabled="{Binding IsEnabled}" 
                                    Width="35" Height="35" Margin="3" FontSize="18"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <TextBlock Text="{Binding CurrentCategory, StringFormat=Category: \{0\}}" FontSize="18" FontWeight="SemiBold" Margin="15,0"/>
                    <TextBlock Text="{Binding Level, StringFormat=Level: \{0\}}" FontSize="18" FontWeight="SemiBold" Margin="15,0"/>
                    <TextBlock Text="{Binding TimeLeft, StringFormat=Time: \{0\}s}" FontSize="18" FontWeight="SemiBold" Foreground="Red" Margin="15,0"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.ColumnSpan="2" Background="#88000000" Visibility="{Binding IsAboutVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="299*"/>
                    <ColumnDefinition Width="81*"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" Width="auto" Height="auto" CornerRadius="8" Grid.ColumnSpan="2" Margin="40,35,40,36">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Nume: nume" FontSize="16" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Text="Grupa: grupa" FontSize="14" Margin="0,5"/>
                        <Button Content="Inchide" Command="{Binding CloseAboutCommand}" Margin="0,20,0,0" Width="100" Height="30"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.ColumnSpan="2" Background="#B2000000" Visibility="{Binding IsSaveLoadOverlayVisible, Converter={StaticResource BoolToVis}}">
                <Border Background="White" Width="auto" Height="auto" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Save game" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <TextBlock Text="Your saved games:" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                        <ListBox ItemsSource="{Binding AvailableSaves}" SelectedItem="{Binding SelectedSave}" Height="110" Margin="0,0,0,10"/>

                        <StackPanel>
                            <TextBlock Text="Save name:" FontSize="12" Foreground="Gray"/>
                            <TextBox Text="{Binding NewSaveName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="3"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Button Content="Save" Command="{Binding ConfirmSaveLoadCommand}" Width="100" Height="30" Margin="10,0"/>
                            <Button Content="Cancel" Command="{Binding CloseSaveLoadOverlayCommand}" Width="100" Height="30" Margin="10,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>