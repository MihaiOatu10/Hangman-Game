<UserControl x:Class="Hangman.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="#FFD8B5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Welcome to Hangman! It is not for the weak!" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="20"/>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Select User" Margin="10" Padding="5">
                <ListBox ItemsSource="{Binding Users}" 
                         SelectedItem="{Binding SelectedUser}" 
                         DisplayMemberPath="Name" 
                         FontSize="16"/>
            </GroupBox>

            <Border Grid.Column="1" Margin="10" Background="White" 
                    BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <Image Source="{Binding SelectedUser.ImagePath}" 
                       Margin="10" Stretch="Uniform">
                    <Image.ToolTip>
                        <ToolTip Content="Avatarul utilizatorului selectat"/>
                    </Image.ToolTip>
                </Image>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="10,10,10,30">
            <Button Content="New User" Command="{Binding ShowNewUserCommand}" 
                    Width="110" Height="35" Margin="8,0"/>
            <Button Content="Delete User" Command="{Binding DeleteUserCommand}" 
                    Width="110" Height="35" Margin="8,0"/>
            <Separator Width="20" Visibility="Hidden"/>
            <Button Content="New Game" Command="{Binding PlayCommand}" 
                    Width="110" Height="35" Margin="8,0" FontWeight="Bold" Background="#FFB2FFB2"/>
            <Button Content="Load Game" Command="{Binding ShowLoadOverlayCommand}" 
                    Width="110" Height="35" Margin="8,0" Background="#FFB2D1FF"/>
            <Button Content="Exit" Command="{Binding CancelCommand}" 
                    Width="110" Height="35" Margin="8,0"/>
        </StackPanel>

        <Grid Grid.RowSpan="3" Background="#88000000" 
              Visibility="{Binding IsCreatingNewUser, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="380" Height="250" 
                    Padding="25" CornerRadius="10" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Create new user" FontSize="18" 
                               FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Name:" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding NewUserName, UpdateSourceTrigger=PropertyChanged}" 
                             Width="300" HorizontalAlignment="Left" Padding="5"/>

                    <Button Content="Choose Avatar Image..." Command="{Binding PickImageCommand}" 
                            Margin="0,15,0,5" Width="150" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding NewUserImagePath}" FontSize="10" 
                               TextWrapping="Wrap" MaxHeight="30" Foreground="Gray" FontStyle="Italic"/>

                    <StackPanel Orientation="Horizontal" Margin="0,25,0,0" HorizontalAlignment="Right">
                        <Button Content="Save" Command="{Binding SaveNewUserCommand}" 
                                Width="90" Height="30" Margin="0,0,10,0"/>
                        <Button Content="Cancel" Command="{Binding HideNewUserCommand}" 
                                Width="90" Height="30"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="3" Background="#B2000000" 
              Visibility="{Binding IsLoadOverlayVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="400" Height="320" 
                    CornerRadius="10" Padding="25" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Load a saved game" FontSize="20" 
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <TextBlock Text="Select a save file from the list:" 
                               FontSize="12" Foreground="DimGray" Margin="0,0,0,5"/>

                    <ListBox ItemsSource="{Binding AvailableSaves}" 
                             SelectedItem="{Binding SelectedSave}" 
                             Height="140" Margin="0,5,0,15" FontSize="14"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Load" Command="{Binding ConfirmLoadCommand}" 
                                Width="110" Height="35" Margin="10,0" FontWeight="Bold"/>
                        <Button Content="Cancel" Command="{Binding HideLoadOverlayCommand}" 
                                Width="110" Height="35" Margin="10,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>